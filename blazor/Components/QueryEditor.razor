@using BlazorMonaco
@using BlazorMonaco.Editor
@inject QueryExecutorService Executor
@inject SceneBuilderService SceneBuilder
@inject SqliteConnectionService ConnSvc

<div class="query-editor">
    <div class="editor-toolbar">
        <button class="btn-run" disabled="@(!Connected)" @onclick="RunQuery">▶ Run</button>
        <button class="btn-visualize" disabled="@(!Connected)" @onclick="VisualizeQuery">⚡ Visualize</button>
        @if (_loading) { <span class="loading-hint">Running…</span> }
        @if (_error != null) { <span class="query-error">@_error</span> }
    </div>

    <div class="monaco-wrapper">
        <StandaloneCodeEditor @ref="_editor"
                              Id="sql-editor"
                              ConstructionOptions="EditorOptions"
                              OnKeyDown="OnKeyDown" />
    </div>

    <div class="results-area">
        <div class="result-tabs">
            <button class="tab active">Results</button>
        </div>

        @if (_plainResult != null)
        {
            @if (_plainResult.Type == "DML")
            {
                <div class="dml-result">✓ @_plainResult.RowsAffected @(_plainResult.RowsAffected == 1 ? "row" : "rows") affected.</div>
            }
            else
            {
                @if (_plainResult.Truncated)
                {
                    <div class="truncation-warning">⚠ Results truncated to 200 rows.</div>
                }
                <div class="results-table-wrap">
                    <table class="results-table">
                        <thead>
                            <tr>@foreach (var col in _plainResult.Columns) { <th>@col.Name</th> }</tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _plainResult.Rows)
                            {
                                <tr>
                                    @foreach (var col in _plainResult.Columns)
                                    {
                                        <td>@(row.TryGetValue(col.Name, out var v) ? v?.ToString() ?? "NULL" : "")</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            <div class="results-hint">Run a query to see results, or hit <strong>Visualize</strong> to open the animated view.</div>
        }
    </div>
</div>

@if (_scene != null)
{
    <VizModal Scene="_scene" OnClose="CloseModal" />
}

@code {
    [Parameter] public EventCallback<VizResult> OnVizResult { get; set; }
    [Parameter] public bool Connected { get; set; }

    private StandaloneCodeEditor? _editor;
    private PlainResult? _plainResult;
    private VizScene? _scene;
    private bool _loading;
    private string? _error;

    private StandaloneEditorConstructionOptions EditorOptions(StandaloneCodeEditor _) =>
        new()
        {
            Language = "sql",
            Theme = "vs-dark",
            Value = "SELECT * FROM students LIMIT 10;",
            Minimap = new EditorMinimapOptions { Enabled = false },
            FontFamily = "JetBrains Mono, Cascadia Code, Consolas, monospace",
            FontSize = 14,
            ScrollBeyondLastLine = false,
            AutomaticLayout = true
        };

    private async Task OnKeyDown(KeyboardEvent e)
    {
        // Ctrl+Enter → Run
        if (e.CtrlKey && e.Code == "Enter")
            await RunQuery();
    }

    private async Task<string?> GetSql()
    {
        if (_editor == null) return null;
        // Check for selection first; fall back to full content
        var selection = await _editor.GetSelection();
        if (selection != null && (selection.StartLineNumber != selection.EndLineNumber ||
                                   selection.StartColumn != selection.EndColumn))
        {
            var model = await _editor.GetModel();
            if (model != null)
                return await model.GetValueInRange(selection, EndOfLinePreference.LF);
        }
        return await _editor.GetValue();
    }

    private async Task RunQuery()
    {
        var sql = await GetSql();
        if (string.IsNullOrWhiteSpace(sql)) return;
        _loading = true; _error = null; _plainResult = null;
        StateHasChanged();
        try
        {
            _plainResult = Executor.RunStatement(sql);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task VisualizeQuery()
    {
        var sql = await GetSql();
        if (string.IsNullOrWhiteSpace(sql)) return;
        _loading = true; _error = null;
        StateHasChanged();
        try
        {
            var result = Executor.VisualizeQuery(sql);
            _scene = SceneBuilder.Build(result);
            await OnVizResult.InvokeAsync(result);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private void CloseModal() => _scene = null;
}
