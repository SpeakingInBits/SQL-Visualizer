@implements IDisposable

<div class="sort-visualizer">
    <div class="viz-header">
        <span class="viz-title">ORDER BY Visualisation</span>
        <span class="viz-hint">Sorting by: <strong>@string.Join(", ", Result.SortKeys)</strong></span>
    </div>

    <div class="anim-controls">
        <button class="btn-step" @onclick="StepBack" disabled="@(_frame <= 0)">⏮</button>
        <button @onclick="TogglePlay">@(_playing ? "⏸" : "▶")</button>
        <button class="btn-step" @onclick="StepForward" disabled="@(_frame >= _steps.Count - 1)">⏭</button>
        <button @onclick="Reset">↺</button>
        <label>Speed
            <input type="range" min="1" max="10" @bind="_speed" @bind:event="oninput" />
            <span class="speed-value">@_speed</span>
        </label>
        <span class="frame-counter">Step @_frame / @(_steps.Count - 1)</span>
    </div>

    <div class="sort-table-wrap">
        <table class="sort-table">
            <thead>
                <tr>
                    @foreach (var col in Result.Columns)
                    {
                        <th class="@(Result.SortKeyIndices.Contains(Result.Columns.IndexOf(col)) ? "sort-key-col" : "")">
                            @col.Name
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (_frame < _steps.Count)
                {
                    @foreach (var (row, state) in _steps[_frame])
                    {
                        <tr class="sort-row @state">
                            @foreach (var col in Result.Columns)
                            {
                                <td>@(row.TryGetValue(col.Name, out var v) ? v?.ToString() ?? "NULL" : "")</td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public OrderByResult Result { get; set; } = null!;

    private int _frame = 0;
    private int _speed = 5;
    private bool _playing = false;
    private System.Threading.Timer? _timer;

    // Each step is a list of (row, cssClass) — mirrors selection-sort animation frames
    private List<List<(Dictionary<string, object?> Row, string State)>> _steps = [];

    protected override void OnParametersSet()
    {
        _frame = 0;
        _playing = false;
        _timer?.Dispose();
        BuildSteps();
    }

    private void BuildSteps()
    {
        _steps.Clear();
        var rows = Result.UnsortedRows.ToList();
        int n = rows.Count;

        // Frame 0: initial unsorted state
        _steps.Add(rows.Select(r => (r, "unsorted")).ToList());

        // Use the pre-sorted order to produce selection-sort frames
        var sortedOrder = Result.SortedRows.ToList();

        var current = rows.ToList();
        for (int i = 0; i < sortedOrder.Count; i++)
        {
            // Find the target row in current (by row identity)
            var target = sortedOrder[i];
            int fromIdx = FindRowIndex(current, target, i);
            if (fromIdx != i)
            {
                // Swap
                (current[i], current[fromIdx]) = (current[fromIdx], current[i]);
            }

            // Produce a frame highlighting the placed row
            var frame = current.Select((r, idx) =>
            {
                string state = idx < i ? "placed" : idx == i ? "comparing" : "unsorted";
                return (r, state);
            }).ToList();
            _steps.Add(frame);
        }

        // Final frame: all placed
        _steps.Add(current.Select(r => (r, "placed")).ToList());
    }

    private static int FindRowIndex(
        List<Dictionary<string, object?>> list,
        Dictionary<string, object?> target,
        int startFrom)
    {
        for (int i = startFrom; i < list.Count; i++)
            if (ReferenceEquals(list[i], target) || RowKey(list[i]) == RowKey(target))
                return i;
        return startFrom;
    }

    private static string RowKey(Dictionary<string, object?> row)
        => string.Join("|", row.Select(kv => $"{kv.Key}={kv.Value}"));

    private void TogglePlay()
    {
        _playing = !_playing;
        if (_playing)
        {
            int intervalMs = Math.Max(100, 1100 - _speed * 100);
            _timer = new System.Threading.Timer(_ =>
            {
                InvokeAsync(() =>
                {
                    if (_frame < _steps.Count - 1) _frame++;
                    else { _playing = false; _timer?.Dispose(); }
                    StateHasChanged();
                });
            }, null, intervalMs, intervalMs);
        }
        else
        {
            _timer?.Dispose();
        }
    }

    private void StepForward() { if (_frame < _steps.Count - 1) _frame++; }
    private void StepBack()    { if (_frame > 0) _frame--; }
    private void Reset()       { _playing = false; _timer?.Dispose(); _frame = 0; }

    public void Dispose() { _timer?.Dispose(); }
}
