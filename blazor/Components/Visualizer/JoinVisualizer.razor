@implements IDisposable
@inject IJSRuntime JS

<div class="join-visualizer">
    <div class="viz-header">
        <span class="viz-title">@Result.JoinType Visualisation</span>
        <span class="viz-hint">ON <code>@Result.OnCondition</code></span>
    </div>

    <div class="anim-controls">
        <button class="btn-step" @onclick="StepBack" disabled="@(_frame <= 0)">⏮</button>
        <button @onclick="TogglePlay">@(_playing ? "⏸" : "▶")</button>
        <button class="btn-step" @onclick="StepForward" disabled="@(_frame >= TotalFrames - 1)">⏭</button>
        <button @onclick="Reset">↺</button>
        <label>Speed
            <input type="range" min="1" max="10" @bind="_speed" @bind:event="oninput" />
            <span class="speed-value">@_speed</span>
        </label>
        <span class="frame-counter">Step @_frame / @(TotalFrames - 1)</span>
    </div>

    <div class="join-layout">
        @* Left table *@
        <div class="join-side left-side">
            <div class="side-title">@Result.LeftTable @(Result.LeftAlias != null ? $"({Result.LeftAlias})" : "")</div>
            <div class="join-table-scroll">
                <table class="join-table">
                    <thead><tr>@foreach (var col in Result.LeftColumns) { <th>@col.Name</th> }</tr></thead>
                    <tbody>
                        @for (int li = 0; li < Result.LeftRows.Count; li++)
                        {
                            var row = Result.LeftRows[li];
                            var state = GetLeftRowState(li);
                            <tr id="left-row-@li" class="join-row @state">
                                @foreach (var col in Result.LeftColumns)
                                {
                                    <td>@(row.TryGetValue(col.Name, out var v) ? v?.ToString() ?? "NULL" : "")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* SVG connector — only the current pair, drawn as a bezier curve *@
        <div class="join-connectors">
            <svg id="join-connector-svg" class="connector-svg" xmlns="http://www.w3.org/2000/svg">
                @if (_pathReady)
                {
                    <path d="M 0,@_pathLeftY C 40,@_pathLeftY 40,@_pathRightY 80,@_pathRightY"
                          fill="none"
                          stroke="var(--accent)"
                          stroke-width="2.5"
                          opacity="0.9" />
                }
            </svg>
        </div>

        @* Right table *@
        <div class="join-side right-side">
            <div class="side-title">@Result.RightTable @(Result.RightAlias != null ? $"({Result.RightAlias})" : "")</div>
            <div class="join-table-scroll">
                <table class="join-table">
                    <thead><tr>@foreach (var col in Result.RightColumns) { <th>@col.Name</th> }</tr></thead>
                    <tbody>
                        @for (int ri = 0; ri < Result.RightRows.Count; ri++)
                        {
                            var row = Result.RightRows[ri];
                            var state = GetRightRowState(ri);
                            <tr id="right-row-@ri" class="join-row @state">
                                @foreach (var col in Result.RightColumns)
                                {
                                    <td>@(row.TryGetValue(col.Name, out var v) ? v?.ToString() ?? "NULL" : "")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* Merged result — revealed at the final frame *@
    @if (_frame == TotalFrames - 1 && Result.MergedRows.Count > 0)
    {
        <div class="merged-result">
            <div class="merged-title">Joined Result (@Result.MergedRows.Count rows)</div>
            <div class="merged-table-wrap">
                <table class="results-table">
                    <thead><tr>@foreach (var col in Result.MergedColumns) { <th>@col.Name</th> }</tr></thead>
                    <tbody>
                        @foreach (var row in Result.MergedRows)
                        {
                            <tr>
                                @foreach (var col in Result.MergedColumns)
                                {
                                    <td>@(row.TryGetValue(col.Name, out var v) ? v?.ToString() ?? "NULL" : "")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public JoinResult Result { get; set; } = null!;

    private int _frame = 0;
    private int _speed = 5;
    private bool _playing = false;
    private bool _measurePending = false;
    private bool _pathReady = false;
    private double _pathLeftY = 0;
    private double _pathRightY = 0;
    private System.Threading.Timer? _timer;

    private record ConnectorYs(double LeftY, double RightY);

    private int TotalFrames => Result.MatchPairs.Count + 1;

    protected override void OnParametersSet()
    {
        _frame = 0;
        _playing = false;
        _measurePending = false;
        _pathReady = false;
        _timer?.Dispose();
        _timer = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_frame > 0 && _frame <= Result.MatchPairs.Count)
        {
            var pair = Result.MatchPairs[_frame - 1];
            var ys = await JS.InvokeAsync<ConnectorYs?>("SqlVis.scrollAndMeasureConnector",
                $"left-row-{pair.L}", $"right-row-{pair.R}", "join-connector-svg");
            if (ys != null)
            {
                bool changed = !_pathReady ||
                    Math.Abs(ys.LeftY  - _pathLeftY)  > 0.5 ||
                    Math.Abs(ys.RightY - _pathRightY) > 0.5;
                _pathLeftY  = ys.LeftY;
                _pathRightY = ys.RightY;
                _pathReady  = true;
                if (changed) StateHasChanged();
            }
        }
        else
        {
            if (_pathReady) { _pathReady = false; StateHasChanged(); }
        }
    }

    private string GetLeftRowState(int rowIdx)
    {
        if (_frame == 0) return "";
        if (Result.MatchPairs[_frame - 1].L == rowIdx) return "active";
        for (int i = 0; i < _frame - 1; i++)
            if (Result.MatchPairs[i].L == rowIdx) return "matched";
        if (_frame == TotalFrames - 1) return "unmatched";
        return "";
    }

    private string GetRightRowState(int rowIdx)
    {
        if (_frame == 0) return "";
        if (Result.MatchPairs[_frame - 1].R == rowIdx) return "active";
        for (int i = 0; i < _frame - 1; i++)
            if (Result.MatchPairs[i].R == rowIdx) return "matched";
        if (_frame == TotalFrames - 1) return "unmatched";
        return "";
    }

    private void TogglePlay()
    {
        _playing = !_playing;
        if (_playing)
        {
            int intervalMs = Math.Max(100, 1100 - _speed * 100);
            _timer = new System.Threading.Timer(_ =>
            {
                InvokeAsync(() =>
                {
                    if (_frame < TotalFrames - 1) _frame++;
                    else { _playing = false; _timer?.Dispose(); }
                    StateHasChanged();
                });
            }, null, intervalMs, intervalMs);
        }
        else
        {
            _timer?.Dispose();
        }
    }

    private void StepForward() { if (_frame < TotalFrames - 1) _frame++; }
    private void StepBack()    { if (_frame > 0) _frame--; }
    private void Reset()       { _playing = false; _timer?.Dispose(); _timer = null; _frame = 0; }

    public void Dispose() { _timer?.Dispose(); }
}
